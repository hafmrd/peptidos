pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: left-panel
    elementType: shape
    shapeName: rect
    bounds: [0, 0, 380, 720]
    fill:
      type: solid
      color: "$primary"
  - elementId: toc-title
    elementType: text
    bounds: [40, 120, 300, 110]
    content:
      text: "PEPTIDE PORTFOLIO"
      fontSize: 36
      fontFamily: "Liter"
      color: "$light"
      lineHeight: 1.2
      align: [left, top]
  - elementId: toc-subtitle
    elementType: text
    bounds: [40, 190, 300, 25]
    content:
      text: "12 FLAGSHIP COMPOUNDS"
      fontSize: 14
      fontFamily: "Liter"
      color: "$tint"
      letterSpacing: 3
      align: [left, middle]
      wrap: false
  - elementId: toc-divider
