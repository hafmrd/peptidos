pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: left-accent
    elementType: shape
    shapeName: rect
    bounds: [0, 0, 8, 720]
    fill:
      type: solid
      color: "$secondary"
  - elementId: product-badge
    elementType: shape
    shapeName: rect
    bounds: [60, 35, 140, 28]
    fill:
      type: solid
      color: "$secondary"
  - elementId: badge-text
    elementType: text
    bounds: [60, 35, 140, 28]
    content:
      text: "SPECIFICATIONS"
      fontSize: 11
      fontFamily: "Liter"
      color: "$light"
      letterSpacing: 1
      align: [center, middle]
      wrap: false
  - elementId: page-title
    elementType: text
    bounds: [60, 75, 600, 40]
    content:
      style: "$pageTitle"
      text: "RETATRUTIDE  —  Technical Data"
      align: [left, middle]
      wrap: false
  - elementId: divider
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 120, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: spec-table
    elementType: table
    bounds: [60, 140, 1160, 470]
    columnWidths: [0.28, 0.72]
    rowHeights: [0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.04]
    style: "$default"
    rows:
      - - content:
            text: "PROPERTY"
        - content:
            text: "VALUE"
      - - content:
            text: "Code"
        - content:
            text: "LY3437943"
      - - content:
            text: "Developer"
        - content:
            text: "Eli Lilly and Company"
      - - content:
            text: "Molecular Weight"
        - content:
            text: "~4700 Da (approximate)"
      - - content:
            text: "Structure"
        - content:
            text: "39-amino acid peptide + C20 fatty diacid moiety"
      - - content:
            text: "Purity"
        - content:
            text: ">99.0% (HPLC / Mass Spectrometry)"
      - - content:
            text: "Physical State"
        - content:
            text: "Lyophilized powder"
      - - content:
            text: "Storage (Lyophilized)"
        - content:
            text: "-20°C, protect from light and moisture"
      - - content:
            text: "Storage (Reconstituted)"
        - content:
            text: "2-8°C, use within 28 days"
      - - content:
            text: "Research Dosage"
        - content:
            text: "1 - 12 mg per week (subcutaneous injection)"
      - - content:
            text: "Administration"
        - content:
            text: "Subcutaneous injection, once weekly"
      - - content:
            text: "Clinical Phase"
        - content:
            text: "Phase 3 (TRIUMPH program)"
      - - content:
            text: "Status"
        - content:
            text: "Investigational — Not yet FDA approved"
  - elementId: footer-line
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 660, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: footer-ruo
    elementType: text
    bounds: [60, 670, 500, 18]
    content:
      style: "$caption"
      text: "FOR RESEARCH USE ONLY  —  NOT FOR HUMAN CONSUMPTION"
      letterSpacing: 1
      align: [left, middle]
      wrap: false
  - elementId: footer-brand
    elementType: text
    bounds: [900, 670, 320, 18]
    content:
      style: "$caption"
      text: "BIOHACKS PHARMACEUTICAL  |  Peptide Science Division"
      align: [right, middle]
      wrap: false
