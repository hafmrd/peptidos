pageType: chapter
background:
  type: solid
  color: "$primary"
elements:
  - elementId: top-bar
    elementType: shape
    shapeName: rect
    bounds: [0, 0, 1280, 5]
    fill:
      type: solid
      color: "$accent"
  - elementId: chapter-num
    elementType: text
    bounds: [80, 100, 300, 140]
    content:
      style: "$chapterNum"
      text: "05"
      align: [left, top]
      wrap: false
  - elementId: chapter-title
    elementType: text
    bounds: [80, 270, 800, 50]
    content:
      style: "$chapterTitle"
      text: "GHK-CU"
      align: [left, middle]
      wrap: false
  - elementId: chapter-subtitle
    elementType: text
    bounds: [80, 330, 800, 30]
    content:
      style: "$subtitle"
      text: "Copper Peptide  |  Skin Rejuvenation & Repair"
      align: [left, middle]
      wrap: false
  - elementId: accent-line
    elementType: shape
    shapeName: straightConnector1
    bounds: [80, 390, 150, 0]
    border:
      style: solid
      width: 3
      color: "$accent"
  - elementId: deco-hex
    elementType: shape
    shapeName: hexagon
    bounds: [950, 400, 250, 250]
    fill:
      type: solid
      color: "#FFFFFF08"
  - elementId: bottom-bar
    elementType: shape
    shapeName: rect
    bounds: [0, 715, 1280, 5]
    fill:
      type: solid
      color: "$accent"
