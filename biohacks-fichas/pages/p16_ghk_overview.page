pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: left-accent
    elementType: shape
    shapeName: rect
    bounds: [0, 0, 8, 720]
    fill:
      type: solid
      color: "$secondary"
  - elementId: product-badge
    elementType: shape
    shapeName: rect
    bounds: [60, 35, 115, 28]
    fill:
      type: solid
      color: "$accent"
  - elementId: badge-text
    elementType: text
    bounds: [60, 35, 115, 28]
    content:
      text: "AESTHETIC"
      fontSize: 11
      fontFamily: "Liter"
      color: "$light"
      letterSpacing: 1
      align: [center, middle]
      wrap: false
  - elementId: page-title
    elementType: text
    bounds: [60, 75, 600, 40]
    content:
      style: "$pageTitle"
      text: "GHK-CU  —  Overview"
      align: [left, middle]
      wrap: false
  - elementId: divider
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 120, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: col1-title
    elementType: text
    bounds: [60, 140, 300, 25]
    content:
      text: "DESCRIPTION"
      fontSize: 14
      fontFamily: "Liter"
      color: "$secondary"
      letterSpacing: 2
      align: [left, middle]
      wrap: false
  - elementId: col1-body
    elementType: text
    bounds: [60, 175, 550, 195]
    content:
      style: "$body"
      fontSize: 15
      lineHeight: 1.6
      text: |
        <p>GHK-Cu is a tripeptide (Gly-His-Lys) complexed with copper(II), first isolated from human plasma. A master regulator of tissue remodeling.</p>
        <p style="margin-top:10px">Upregulates ~4,000 human genes involved in regenerative processes. GHK levels decline from ~200 ng/mL (age 20) to ~80 ng/mL (age 60). Copper ion is essential for biological activity.</p>
      align: [left, top]
  - elementId: col2-title
    elementType: text
    bounds: [660, 140, 300, 25]
    content:
      text: "MECHANISM OF ACTION"
      fontSize: 14
      fontFamily: "Liter"
      color: "$secondary"
      letterSpacing: 2
      align: [left, middle]
      wrap: false
  - elementId: mech-body
    elementType: text
    bounds: [660, 175, 560, 195]
    content:
      style: "$body"
      fontSize: 15
      lineHeight: 1.6
      text: |
        <p>Multi-target regenerative actions:</p>
        <ul>
        <li>Stimulates collagen and elastin synthesis</li>
        <li>Promotes wound healing and angiogenesis</li>
        <li>Potent antioxidant activity (ROS scavenging)</li>
        <li>Anti-inflammatory via TGF-beta suppression</li>
        <li>Hair follicle growth stimulation</li>
        </ul>
      align: [left, top]
  - elementId: clinical-title
    elementType: text
    bounds: [60, 395, 300, 25]
    content:
      text: "RESEARCH HIGHLIGHTS"
      fontSize: 14
      fontFamily: "Liter"
      color: "$secondary"
      letterSpacing: 2
      align: [left, middle]
      wrap: false
  - elementId: data-card-1-bg
    elementType: shape
    shapeName: rect
    bounds: [60, 430, 250, 100]
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: data-1-num
    elementType: text
    bounds: [75, 440, 220, 45]
    content:
      style: "$dataHighlight"
      text: "~4,000"
      align: [left, middle]
      wrap: false
  - elementId: data-1-label
    elementType: text
    bounds: [75, 490, 220, 30]
    content:
      style: "$label"
      text: "Human genes upregulated"
      lineHeight: 1.3
      align: [left, top]
  - elementId: data-card-2-bg
    elementType: shape
    shapeName: rect
    bounds: [330, 430, 250, 100]
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: data-2-num
    elementType: text
    bounds: [345, 440, 220, 45]
    content:
      style: "$dataHighlight"
      text: "1973"
      align: [left, middle]
      wrap: false
  - elementId: data-2-label
    elementType: text
    bounds: [345, 490, 220, 30]
    content:
      style: "$label"
      text: "Year first isolated (human plasma)"
      lineHeight: 1.3
      align: [left, top]
  - elementId: data-card-3-bg
    elementType: shape
    shapeName: rect
    bounds: [600, 430, 250, 100]
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: data-3-num
    elementType: text
    bounds: [615, 440, 220, 45]
    content:
      style: "$dataHighlight"
      text: "60%"
      align: [left, middle]
      wrap: false
  - elementId: data-3-label
    elementType: text
    bounds: [615, 490, 220, 30]
    content:
      style: "$label"
      text: "Decline in GHK levels by age 60"
      lineHeight: 1.3
      align: [left, top]
  - elementId: data-card-4-bg
    elementType: shape
    shapeName: rect
    bounds: [870, 430, 350, 100]
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: data-4-num
    elementType: text
    bounds: [885, 440, 320, 45]
    content:
      style: "$dataHighlight"
      text: "Cu2+"
      align: [left, middle]
      wrap: false
  - elementId: data-4-label
    elementType: text
    bounds: [885, 490, 320, 30]
    content:
      style: "$label"
      text: "Copper(II) essential for activity"
      lineHeight: 1.3
      align: [left, top]
  - elementId: footer-line
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 660, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: footer-ruo
    elementType: text
    bounds: [60, 670, 500, 18]
    content:
      style: "$caption"
      text: "FOR RESEARCH USE ONLY  —  NOT FOR HUMAN CONSUMPTION"
      letterSpacing: 1
      align: [left, middle]
      wrap: false
  - elementId: footer-brand
    elementType: text
    bounds: [900, 670, 320, 18]
    content:
      style: "$caption"
      text: "BIOHACKS PHARMACEUTICAL  |  Peptide Science Division"
      align: [right, middle]
      wrap: false
