      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: data-4-num
    elementType: text
    bounds: [885, 440, 320, 45]
    content:
      style: "$dataHighlight"
      text: "Stack"
      align: [left, middle]
      wrap: false
  - elementId: data-4-label
    elementType: text
    bounds: [885, 490, 320, 30]
