    shapeName: straightConnector1
    bounds: [60, 660, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: footer-ruo
    elementType: text
    bounds: [60, 670, 500, 18]
    content:
      style: "$caption"
      text: "FOR RESEARCH USE ONLY  —  NOT FOR HUMAN CONSUMPTION"
      letterSpacing: 1
