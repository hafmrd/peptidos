pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: left-accent
    elementType: shape
    shapeName: rect
    bounds: [0, 0, 8, 720]
    fill:
      type: solid
      color: "$secondary"
  - elementId: product-badge
    elementType: shape
    shapeName: rect
    bounds: [60, 35, 140, 28]
    fill:
      type: solid
      color: "$secondary"
  - elementId: badge-text
    elementType: text
    bounds: [60, 35, 140, 28]
    content:
      text: "SPECIFICATIONS"
      fontSize: 11
      fontFamily: "Liter"
      color: "$light"
      letterSpacing: 1
      align: [center, middle]
      wrap: false
  - elementId: page-title
    elementType: text
    bounds: [60, 75, 600, 40]
    content:
      style: "$pageTitle"
      text: "SEMAX  —  Technical Data"
      align: [left, middle]
      wrap: false
  - elementId: divider
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 120, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: spec-table
    elementType: table
    bounds: [60, 140, 1160, 470]
    columnWidths: [0.28, 0.72]
    rowHeights: [0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.08, 0.04]
    style: "$default"
    rows:
      - - content:
            text: "PROPERTY"
        - content:
            text: "VALUE"
      - - content:
            text: "CAS Number"
        - content:
            text: "80714-61-0"
      - - content:
            text: "Molecular Formula"
        - content:
            text: "C37H51N9O10S"
      - - content:
            text: "Molecular Weight"
        - content:
            text: "813.93 g/mol"
      - - content:
            text: "Purity"
        - content:
            text: ">99.0% (HPLC / Mass Spectrometry)"
      - - content:
            text: "Sequence"
        - content:
            text: "Met-Glu-His-Phe-Pro-Gly-Pro"
      - - content:
            text: "Physical State"
        - content:
            text: "Lyophilized powder"
      - - content:
            text: "Storage (Lyophilized)"
        - content:
            text: "-20°C, protect from light"
      - - content:
            text: "Storage (Reconstituted)"
        - content:
            text: "2-8°C, use within 14 days"
      - - content:
            text: "Reconstitution"
        - content:
            text: "Bacteriostatic saline"
      - - content:
            text: "Research Dosage"
        - content:
            text: "300 - 900 mcg daily"
      - - content:
            text: "Administration"
        - content:
            text: "Intranasal or subcutaneous"
      - - content:
            text: "Shelf Life"
        - content:
            text: "24 months from date of manufacture (lyophilized)"
  - elementId: footer-line
    elementType: shape
    shapeName: straightConnector1
    bounds: [60, 660, 1160, 0]
    border:
      style: solid
      width: 1
      color: "#E6F1FB"
  - elementId: footer-ruo
    elementType: text
    bounds: [60, 670, 500, 18]
    content:
      style: "$caption"
      text: "FOR RESEARCH USE ONLY  —  NOT FOR HUMAN CONSUMPTION"
      letterSpacing: 1
      align: [left, middle]
      wrap: false
  - elementId: footer-brand
    elementType: text
    bounds: [900, 670, 320, 18]
    content:
      style: "$caption"
      text: "BIOHACKS PHARMACEUTICAL  |  Peptide Science Division"
      align: [right, middle]
      wrap: false
